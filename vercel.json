{
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/westside", "destination": "/westside/index.html" },
    { "source": "/westside/dashboard", "destination": "/westside/dashboard.html" },
    { "source": "/westside/content", "destination": "/westside/content.html" },
    { "source": "/westside/calendar", "destination": "/westside/calendar.html" },
    { "source": "/aviation", "destination": "/aviation/index.html" },
    { "source": "/aviation/dashboard", "destination": "/aviation/dashboard.html" },
    { "source": "/aviation/email-parse", "destination": "/aviation/email-parse.html" },
    { "source": "/burbuja", "destination": "/burbuja/index.html" },
    { "source": "/burbuja/dashboard", "destination": "/burbuja/dashboard.html" },
    { "source": "/eco", "destination": "/eco/index.html" },
    { "source": "/eco/builder", "destination": "/eco/builder.html" },
    { "source": "/eco/studio", "destination": "/eco/studio.html" },
    { "source": "/prototypes/westside", "destination": "/prototypes/westside/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "max-age=0, must-revalidate" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
